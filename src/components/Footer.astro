---
import { profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
	<p class="site-footer__copy">© {currentYear} {profileConfig.name} 版权所有</p>
	<p class="site-footer__meta">
		<a href={url("rss.xml")} class="site-footer__link">RSS</a>
		<span class="site-footer__dot">/</span>
		<span>由</span>
		<a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="site-footer__link">Astro</a>
		<span>和</span>
		<a href="https://github.com/saicaca/fuwari" target="_blank" rel="noopener noreferrer" class="site-footer__link">Fuwari</a>
		<span>驱动</span>
	</p>
</footer>

<style>
	.site-footer {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		text-align: center;
		padding: 1.25rem 1rem 1.75rem;
		font-size: 0.85rem;
		line-height: 1.4;
		width: fit-content;
		max-width: calc(100% - 1rem);
		margin: 0 auto;
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(10px) saturate(140%);
		-webkit-backdrop-filter: blur(10px) saturate(140%);
		border: 1px solid rgba(255, 255, 255, 0.65);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}

	.site-footer__copy {
		color: rgba(0, 0, 0, 0.82);
		font-weight: 600;
		text-shadow: 0 1px 1px rgba(255, 255, 255, 0.5);
	}

	:global(.dark) .site-footer {
		background: rgba(20, 20, 20, 0.72);
		border: 1px solid rgba(255, 255, 255, 0.16);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.32);
	}

	:global(.dark) .site-footer__copy {
		color: rgba(255, 255, 255, 0.92);
		text-shadow: 0 1px 1px rgba(0, 0, 0, 0.4);
	}

	.site-footer__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		color: rgba(0, 0, 0, 0.65);
	}

	:global(.dark) .site-footer__meta {
		color: rgba(255, 255, 255, 0.7);
	}

	.site-footer__link {
		color: color-mix(in oklab, var(--primary) 88%, black 12%);
		text-decoration: none;
		font-weight: 500;
	}

	:global(.dark) .site-footer__link {
		color: color-mix(in oklab, var(--primary) 85%, white 15%);
	}

	.site-footer__link:hover {
		text-decoration: underline;
		text-underline-offset: 0.2rem;
	}

	.site-footer__dot {
		opacity: 0.6;
	}
</style>
