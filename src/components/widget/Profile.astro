---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import avatar from "../../assets/images/12.png";

const config = profileConfig;

const posts = await getCollection("posts", ({ data }) => {
	return import.meta.env.PROD ? data.draft !== true : true;
});

// Use each post's rendered frontmatter words to keep total count consistent with post cards/pages.
const wordsPerPost = await Promise.all(
	posts.map(async (post) => {
		const { remarkPluginFrontmatter } = await post.render();
		return Number(remarkPluginFrontmatter.words ?? 0);
	}),
);

const postCount = posts.length;
const totalWords = wordsPerPost.reduce((sum, words) => sum + words, 0);
const postCountText = new Intl.NumberFormat("zh-CN").format(postCount);
const totalWordsText = new Intl.NumberFormat("zh-CN").format(totalWords);

const postsLabel = "\u6587\u7ae0";
const wordsLabel = "\u603b\u5b57\u6570";
const postsUnit = "\u7bc7";
const wordsUnit = "\u5b57";
---

<div class="card-base p-3 sm:p-4">
	<div class="block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       w-28 h-28 sm:w-32 sm:h-32 lg:w-auto lg:h-auto
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-full user-select-none">
		<div class="overflow-hidden relative">
			<Image
				src={avatar}
				alt="Profile Image of the Author"
				class="w-full h-full object-cover mx-auto lg:w-full lg:h-full lg:mt-0"
				loading="eager"
				decoding="async"
				format="webp"
				quality={85}
				draggable={false}
			/>
		</div>
	</div>
	<div class="px-1 sm:px-2">
		<div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition user-select-none">{config.name}</div>
		<div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
		<div class="text-center text-sm sm:text-base text-neutral-400 mb-2.5 transition user-select-none">{config.bio}</div>
		<div class="flex flex-wrap gap-2 justify-center mb-1">
			{config.links.length > 1 && config.links.map((item) =>
				<a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-9 w-9 sm:h-10 sm:w-10 active:scale-90">
					<Icon name={item.icon} class="text-[1.5rem]"></Icon>
				</a>,
			)}
			{config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
				class="btn-regular rounded-lg h-9 sm:h-10 gap-2 px-3 font-bold active:scale-95">
				<Icon name={config.links[0].icon} class="text-[1.5rem]"></Icon>
				{config.links[0].name}
			</a>}
		</div>

		<div class="mt-3 pt-3 border-t border-black/10 dark:border-white/10">
			<div class="grid grid-cols-2 gap-2">
				<div class="rounded-lg bg-black/[0.04] dark:bg-white/[0.06] px-2 py-2 text-center">
					<div class="inline-flex items-center text-[var(--primary)] mb-1">
						<Icon name="material-symbols:article-outline-rounded" class="text-[1rem] mr-1"></Icon>
						<span class="text-xs">{postsLabel}</span>
					</div>
					<div class="text-sm font-semibold text-90">{postCountText} {postsUnit}</div>
				</div>
				<div class="rounded-lg bg-black/[0.04] dark:bg-white/[0.06] px-2 py-2 text-center">
					<div class="inline-flex items-center text-[var(--primary)] mb-1">
						<Icon name="material-symbols:notes-rounded" class="text-[1rem] mr-1"></Icon>
						<span class="text-xs">{wordsLabel}</span>
					</div>
					<div class="text-sm font-semibold text-90">{totalWordsText} {wordsUnit}</div>
				</div>
			</div>
		</div>
	</div>
</div>

