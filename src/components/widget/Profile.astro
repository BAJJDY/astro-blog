---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;

const posts = await getCollection("posts", ({ data }) => data.draft !== true);
const postCount = posts.length;
const wordCounts = await Promise.all(
	posts.map(async (post) => {
		const { remarkPluginFrontmatter } = await post.render();
		return Number(remarkPluginFrontmatter?.words || 0);
	}),
);
const totalTextCount = wordCounts.reduce((total, words) => total + words, 0);

const postLabel = "\u6587\u7ae0\u6570";
const totalWordsLabel = "\u603b\u5b57\u6570";
---
<div class="card-base p-3">
    <div class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-full">
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 " draggable="false"></ImageWrapper>
    </div>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{config.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        <div class="text-center text-neutral-400 mb-2.5 transition">{config.bio}</div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                <Icon name={config.links[0].icon} class="text-[1.5rem]"></Icon>
                {config.links[0].name}
            </a>}
        </div>
        <div class="mt-3 pt-3 border-t border-black/10 dark:border-white/10">
            <div class="grid grid-cols-2">
                <div class="text-center px-2 border-r border-black/10 dark:border-white/10">
                    <div class="text-xs text-50 inline-flex items-center gap-1 mb-1">
                        <Icon name="material-symbols:article-outline-rounded" class="text-[1rem]"></Icon>
                        <span>{postLabel}</span>
                    </div>
                    <div class="text-2xl font-bold text-90 leading-none">{postCount}</div>
                </div>
                <div class="text-center px-2">
                    <div class="text-xs text-50 inline-flex items-center gap-1 mb-1">
                        <Icon name="material-symbols:text-fields-rounded" class="text-[1rem]"></Icon>
                        <span>{totalWordsLabel}</span>
                    </div>
                    <div class="text-2xl font-bold text-90 leading-none">{totalTextCount.toLocaleString()}</div>
                </div>
            </div>
        </div>
    </div>
</div>
